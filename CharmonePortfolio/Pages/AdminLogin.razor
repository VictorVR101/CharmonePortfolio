@page "/admin"
@using CharmonePortfolio.Services
@inject SupabaseService Supabase
@inject NavigationManager Nav

@if (Supabase.IsAuthenticated)
{
    Nav.NavigateTo("/admin/dashboard");
}

<div class="admin-login-page">
    <div class="admin-login-card">

        <div class="admin-login-header">
            <p class="admin-eyebrow">Admin</p>
            <h1 class="admin-login-title">Sign In</h1>
        </div>

        <div class="contact-form-wrap">
            <div class="form-group">
                <label class="form-label">Email</label>
                <input class="form-input"
                       type="email"
                       placeholder="your@email.com"
                       @bind="Email"
                       @bind:event="oninput" />
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <input class="form-input"
                       type="password"
                       placeholder="••••••••"
                       @bind="Password"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <p class="status-error">@ErrorMessage</p>
            }

            <button class="btn-primary"
                    @onclick="LoginAsync"
                    disabled="@IsLoading">
                @(IsLoading ? "Signing in..." : "Sign In")
            </button>
        </div>

    </div>
</div>

@code {
    private string Email = "";
    private string Password = "";
    private string ErrorMessage = "";
    private bool IsLoading = false;

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Please enter your email and password.";
            return;
        }

        IsLoading = true;
        ErrorMessage = "";

        var success = await Supabase.LoginAsync(Email, Password);

        if (success)
            Nav.NavigateTo("/admin/dashboard");
        else
            ErrorMessage = "Invalid email or password. Please try again.";

        IsLoading = false;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoginAsync();
    }
}

<style>
    .admin-login-page {
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background-color: var(--color-bg);
    }

    .admin-login-card {
        width: 100%;
        max-width: 420px;
        padding: 3rem;
        background-color: var(--color-card);
        border: 1px solid var(--color-border);
    }

    .admin-login-header {
        margin-bottom: 2.5rem;
    }

    .admin-eyebrow {
        font-size: 0.7rem;
        letter-spacing: 4px;
        color: var(--color-gold);
        text-transform: uppercase;
        margin-bottom: 0.5rem;
    }

    .admin-login-title {
        font-size: 2.5rem;
        font-weight: 400;
        color: var(--color-accent);
        line-height: 1;
        letter-spacing: -1px;
    }
</style>
