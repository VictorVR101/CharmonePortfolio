@page "/"

<PageTitle>Charmone Strauss — Design Portfolio</PageTitle>

<div class="hero">

    <!-- Left: Full bleed photo -->
    <div class="hero-photo-col">
        <img src="images/charmone-hero.png"
             alt="Charmone Strauss"
             class="hero-photo" />
        <div class="hero-photo-fade"></div>
    </div>

    <!-- Right: Text -->
    <div class="hero-content">
        <p class="hero-eyebrow">Design Student · Greenside Design Center</p>
        <h1 class="hero-title">
            <span>Charmone</span>
            <span>Strauss</span>
        </h1>
        <div class="hero-rule"></div>
        <p class="hero-sub">
            A design student crafting meaningful visual experiences through
            typography, illustration, and multimedia storytelling.
        </p>
        <div class="hero-buttons">
            <a href="/portfolio" class="btn-primary">View Work</a>
            <a href="/contact" class="btn-outline">Get In Touch</a>
        </div>
        <div class="hero-scroll-hint">
            <div class="hero-scroll-line"></div>
            Scroll
        </div>
    </div>

</div>

<style>
    /* ══════════════════════════════════════
           DESKTOP — side by side
        ══════════════════════════════════════ */
    .hero {
        min-height: calc(100vh - 70px);
        display: grid;
        grid-template-columns: 45% 1fr;
        background-color: var(--color-bg);
        position: relative;
        overflow: hidden;
    }

    /* Photo bleeds full height on the left */
    .hero-photo-col {
        position: relative;
        min-height: calc(100vh - 70px);
        overflow: hidden;
        background-color: var(--color-surface);
    }

    .hero-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
        mix-blend-mode: multiply;
    }

    /* Right-edge fade so photo blends into bg */
    .hero-photo-fade {
        position: absolute;
        top: 0;
        right: 0;
        width: 140px;
        height: 100%;
        background: linear-gradient(to right, transparent, var(--color-bg));
    }

    /* Night mode adjustments */
    [data-theme="night"] .hero-photo {
        mix-blend-mode: normal;
        opacity: 0.9;
    }

    [data-theme="night"] .hero-photo-col {
        background-color: #150A0A;
    }

    [data-theme="night"] .hero-photo-fade {
        background: linear-gradient(to right, transparent, #150A0A);
    }

    /* Right text column */
    .hero-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 4rem 5vw 4rem 3vw;
        position: relative;
        z-index: 2;
    }

    .hero-eyebrow {
        font-size: 0.65rem;
        letter-spacing: 5px;
        color: var(--color-gold);
        text-transform: uppercase;
        margin-bottom: 1.4rem;
    }

    .hero-title {
        font-size: 6.5rem;
        font-weight: 400;
        color: var(--color-accent);
        line-height: 0.92;
        letter-spacing: -3px;
        margin-bottom: 1.8rem;
    }

        .hero-title span {
            display: block;
        }

    .hero-rule {
        width: 48px;
        height: 1.5px;
        background-color: var(--color-gold);
        margin-bottom: 1.5rem;
        flex-shrink: 0;
    }

    .hero-sub {
        font-size: 1rem;
        color: var(--color-text-secondary);
        max-width: 380px;
        line-height: 1.9;
        margin-bottom: 2.5rem;
    }

    .hero-buttons {
        display: flex;
        gap: 1rem;
        margin-bottom: 3.5rem;
    }

    .hero-scroll-hint {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.6rem;
        letter-spacing: 3px;
        color: var(--color-gold);
        text-transform: uppercase;
        opacity: 0.6;
    }

    .hero-scroll-line {
        width: 30px;
        height: 1px;
        background-color: var(--color-gold);
    }

    /* ══════════════════════════════════════
           MOBILE — Option B layout
           Maroon header block with portrait card
           sitting half in / half out, text below
        ══════════════════════════════════════ */
    @@media (max-width: 768px) {

        .hero {
            grid-template-columns: 1fr;
            grid-template-rows: auto auto;
            min-height: unset;
            overflow: visible;
        }
        /* Maroon header block — photo col becomes the coloured top band */
        .hero-photo-col {
            background-color: var(--color-accent);
            min-height: unset;
            height: auto;
            padding-top: 2.5rem;
            padding-bottom: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow: visible;
            position: relative;
        }
        /* Hide the right-edge fade on mobile */
        .hero-photo-fade {
            display: none;
        }
        /* Name sits inside the maroon block above the portrait */
        .hero-photo-col::before {
            content: 'Charmone Strauss';
            display: block;
            font-family: Georgia, serif;
            font-size: 2.6rem;
            font-weight: 400;
            color: var(--color-navbar-text);
            line-height: 0.95;
            letter-spacing: -1px;
            text-align: center;
            padding: 0 1.5rem 1.5rem;
        }
        /* Portrait card — centred, half overlapping into the white section */
        .hero-photo {
            width: 200px;
            height: 240px;
            object-fit: cover;
            object-position: center 15%;
            display: block;
            mix-blend-mode: normal;
            border: 2px solid rgba(184, 138, 44, 0.6);
            margin-bottom: -60px; /* overlap into text section below */
            position: relative;
            z-index: 3;
            flex-shrink: 0;
        }

        [data-theme="night"] .hero-photo-col {
            background-color: #3A0808;
        }
        /* Text content below — hides its own title since it's shown in ::before */
        .hero-content {
            padding: 80px 1.5rem 3rem; /* 80px top gives room for the overlapping portrait */
            align-items: center;
            text-align: center;
            background-color: var(--color-bg);
        }
        /* Hide the desktop eyebrow and title — shown in the maroon block instead */
        .hero-eyebrow {
            display: none;
        }

        .hero-title {
            display: none;
        }

        .hero-rule {
            margin: 0 auto 1.4rem;
        }

        .hero-sub {
            max-width: 100%;
            font-size: 0.95rem;
        }

        .hero-buttons {
            flex-direction: column;
            width: 100%;
            margin-bottom: 2rem;
        }

        .btn-primary,
        .btn-outline {
            text-align: center;
        }

        .hero-scroll-hint {
            display: none;
        }
    }
</style>
