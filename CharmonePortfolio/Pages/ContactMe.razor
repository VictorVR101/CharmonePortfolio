@page "/contact"
@inject IJSRuntime JS

<PageTitle>Contact | Charmone Strauss</PageTitle>

<div class="contact-page">

    <div class="contact-hero">
        <div class="about-tag">GET IN TOUCH</div>
        <h1 class="about-title">Contact<br />Me</h1>
    </div>

    <div class="contact-grid">

        <div class="contact-details">
            <div class="contact-block">
                <div class="about-label">EMAIL</div>
                <p class="contact-info">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B88A2C" stroke-width="1.5">
                        <rect x="2" y="4" width="20" height="16" rx="2" />
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                    charmone.strauss06@@gmail.com
                </p>
            </div>
            <div class="about-divider"></div>
            <div class="contact-block">
                <div class="about-label">PHONE</div>
                <p class="contact-info">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B88A2C" stroke-width="1.5">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6 6l1.27-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                    +27 66 295 8619
                </p>
            </div>
            <div class="about-divider"></div>
            <div class="contact-block">
                <div class="about-label">LOCATION</div>
                <p class="contact-info">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B88A2C" stroke-width="1.5">
                        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                        <circle cx="12" cy="10" r="3" />
                    </svg>
                    South Africa
                </p>
            </div>
            <div class="about-divider"></div>
            <div class="contact-block">
                <div class="about-label">INSTAGRAM</div>
                <p class="contact-info">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B88A2C" stroke-width="1.5">
                        <rect x="2" y="2" width="20" height="20" rx="5" />
                        <circle cx="12" cy="12" r="4" />
                        <circle cx="17.5" cy="6.5" r="1" fill="#B88A2C" />
                    </svg>
                    @@xx_neitjie_xx8
                </p>
            </div>
        </div>

        <div class="contact-form-wrap">
            <div class="form-group">
                <label class="form-label">YOUR NAME</label>
                <input class="form-input" @bind="name" placeholder="Jane Doe" />
            </div>
            <div class="form-group">
                <label class="form-label">YOUR EMAIL</label>
                <input class="form-input" @bind="email" placeholder="jane@email.com" />
            </div>
            <div class="form-group">
                <label class="form-label">SUBJECT</label>
                <input class="form-input" @bind="subject" placeholder="Project enquiry" />
            </div>
            <div class="form-group">
                <label class="form-label">MESSAGE</label>
                <textarea class="form-input form-textarea" @bind="message" placeholder="Tell me about your project..."></textarea>
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <p class="form-status @statusClass">@statusMessage</p>
            }

            <button class="btn-primary" @onclick="SendMessage" disabled="@sending">
                @(sending ? "SENDING..." : "SEND MESSAGE")
            </button>
        </div>

    </div>

</div>

@code {
    private string name = "";
    private string email = "";
    private string subject = "";
    private string message = "";
    private string statusMessage = "";
    private string statusClass = "";
    private bool sending = false;

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(message))
        {
            statusMessage = "Please fill in all fields.";
            statusClass = "status-error";
            return;
        }

        sending = true;
        statusMessage = "";

        try
        {
            var result = await JS.InvokeAsync<bool>("sendEmail", name, email, subject, message);
            if (result)
            {
                statusMessage = "Message sent successfully! I'll get back to you soon.";
                statusClass = "status-success";
                name = email = subject = message = "";
            }
            else
            {
                statusMessage = "Something went wrong. Please try again.";
                statusClass = "status-error";
            }
        }
        catch
        {
            statusMessage = "Something went wrong. Please try again.";
            statusClass = "status-error";
        }

        sending = false;
    }
}

