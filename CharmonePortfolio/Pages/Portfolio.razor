            ? AllProjects
            : AllProjects.Where(p => p.Category == ActiveFilter);

    private int ComingSoonCount => Math.Max(0, 3 - FilteredProjects.Count());

    private void SetFilter(string filter) => ActiveFilter = filter;

    // ─── Modal State ───────────────────────────────────────────
    private Project? SelectedProject;
    private string? ZoomedImageUrl;
    private int CurrentImageIndex = 0;

    private void OpenModal(Project project)
    {
        SelectedProject = project;
        CurrentImageIndex = 0;
        ZoomedImageUrl = null;
    }

    private void CloseModal()
    {
        SelectedProject = null;
        ZoomedImageUrl = null;
    }

    private void NextImage()
    {
        if (SelectedProject?.Images != null && CurrentImageIndex < SelectedProject.Images.Count - 1)
            CurrentImageIndex++;
    }

    private void PrevImage()
    {
        if (CurrentImageIndex > 0)
            CurrentImageIndex--;
    }

    private void OpenZoom(string imageUrl) => ZoomedImageUrl = imageUrl;
    private void CloseZoom() => ZoomedImageUrl = null;
