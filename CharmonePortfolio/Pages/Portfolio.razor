@page "/portfolio"
@using CharmonePortfolio.Services
@inject IJSRuntime JS
@inject SupabaseService Supabase

<PageTitle>Portfolio — Charmone Strauss</PageTitle>

<div class="portfolio-page">

    <!-- Page Header -->
    <section class="portfolio-header">
        <div class="portfolio-header-inner">
            <p class="portfolio-eyebrow">Creative Work</p>
            <h1 class="portfolio-title">Portfolio</h1>
            <p class="portfolio-subtitle">
                A collection of projects spanning photography, graphic design, and multimedia storytelling.
            </p>
        </div>
    </section>

    <!-- Filter Bar -->
    <section class="portfolio-filters">
        <div class="portfolio-filters-inner">
            @foreach (var filter in Filters)
            {
                <button class="filter-btn @(ActiveFilter == filter ? "active" : "")"
                        @onclick="() => SetFilter(filter)">
                    @filter
                </button>
            }
        </div>
    </section>

    <!-- Loading state -->
    @if (IsLoading)
    {
        <div style="text-align:center;padding:6rem 2rem;">
            <p class="portfolio-eyebrow">Loading projects...</p>
        </div>
    }
    else
    {
        <!-- Project Grid -->
        <section class="portfolio-grid-section">
            <div class="portfolio-grid">
                @foreach (var project in FilteredProjects)
                {
                    <div class="project-card @(project.Featured ? "project-card--featured" : "")"
                         @onclick="() => OpenModal(project)">
                        <div class="project-card-image">
                            @if (!string.IsNullOrEmpty(project.Thumbnail))
                            {
                                <img src="@(project.Folder + project.Thumbnail)"
                                     alt="@project.Title" loading="lazy" />
                            }
                            else
                            {
                                <div class="project-card-placeholder">
                                    <span class="placeholder-icon">🖼</span>
                                </div>
                            }
                            @if (project.Featured)
                            {
                                <div class="featured-badge">Featured</div>
                            }
                            <div class="project-card-overlay">
                                <span class="view-label">View Project</span>
                            </div>
                        </div>
                        <div class="project-card-info">
                            <span class="project-tag">@project.Category</span>
                            <h3 class="project-card-title">@project.Title</h3>
                            <p class="project-card-desc">@project.Description</p>
                            <div class="project-card-meta">
                                <span class="project-term">@project.Term</span>
                                <div class="project-media-icons">
                                    @if (project.Images?.Count > 0)
                                    {
                                        <span title="Images">📷</span>
                                    }
                                    @if (project.VideoUrls?.Count > 0)
                                    {
                                        <span title="Video">🎬</span>
                                    }
                                    @if (!string.IsNullOrEmpty(project.PdfUrl))
                                    {
                                        <span title="PDF">📄</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Coming Soon Placeholders -->
                @for (int i = 0; i < ComingSoonCount; i++)
                {
                    <div class="project-card coming-soon">
                        <div class="project-card-image">
                            <div class="project-card-placeholder">
                                <span class="placeholder-icon coming-soon-icon">✦</span>
                                <span class="coming-soon-text">Coming Soon</span>
                            </div>
                        </div>
                        <div class="project-card-info">
                            <span class="project-tag">—</span>
                            <h3 class="project-card-title">New Project</h3>
                            <p class="project-card-desc">More work coming soon.</p>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

</div>

<!-- Modal Lightbox -->
@if (SelectedProject != null)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-panel" @onclick:stopPropagation="true">

            <button class="modal-close" @onclick="CloseModal" title="Close">✕</button>

            <div class="modal-body">

                <!-- Media Section -->
                <div class="modal-media">
                    @{
                        var allMedia = GetAllMedia(SelectedProject);
                    }
                    @if (allMedia.Count > 0)
                    {
                        var current = allMedia[CurrentImageIndex];
                        <div class="modal-image-viewer">

                            @if (current.Type == MediaItemType.Video)
                            {
                                <video controls autoplay class="modal-main-video">
                                    <source src="@current.Url" type="video/mp4" />
                                    Your browser does not support video.
                                </video>
                            }
                            else
                            {
                                <img src="@current.Url"
                                     alt="@SelectedProject.Title"
                                     class="modal-main-image"
                                     @onclick="() => OpenZoom(current.Url)"
                                     @onclick:stopPropagation="true" />
                            }

                            @if (allMedia.Count > 1)
                            {
                                <div class="modal-image-nav">
                                    <button class="img-nav-btn" @onclick="PrevImage"
                                            disabled="@(CurrentImageIndex == 0)">
                                        ‹
                                    </button>
                                    <span class="img-counter">
                                        @(CurrentImageIndex + 1) / @allMedia.Count
                                    </span>
                                    <button class="img-nav-btn" @onclick="NextImage"
                                            disabled="@(CurrentImageIndex == allMedia.Count - 1)">
                                        ›
                                    </button>
                                </div>

                                <div class="modal-thumbnails">
                                    @for (int i = 0; i < allMedia.Count; i++)
                                    {
                                        int idx = i;
                                        var item = allMedia[i];
                                        <div class="modal-thumb-wrap @(CurrentImageIndex == idx ? "active" : "")"
                                             @onclick="() => SelectMedia(idx)">
                                            @if (item.Type == MediaItemType.Video)
                                            {
                                                <div class="modal-thumb modal-thumb--video">🎬</div>
                                            }
                                            else
                                            {
                                                <img src="@item.Url" alt="Thumb @(i + 1)" class="modal-thumb" />
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="modal-no-media">
                            <span>🖼</span>
                            <p>Images coming soon</p>
                        </div>
                    }
                </div>

                <!-- Info Section -->
                <div class="modal-info">
                    <span class="modal-tag">@SelectedProject.Category</span>
                    <h2 class="modal-title">@SelectedProject.Title</h2>
                    <p class="modal-term">@SelectedProject.Term</p>
                    <p class="modal-description">@SelectedProject.Description</p>

                    @if (!string.IsNullOrEmpty(SelectedProject.PdfUrl))
                    {
                        <a href="@(SelectedProject.Folder + SelectedProject.PdfUrl)"
                               target="_blank" class="modal-pdf-btn">
                            📄 View PDF Document
                        </a>
                    }

                    @if (SelectedProject.Tags?.Count > 0)
                    {
                        <div class="modal-tags">
                            @foreach (var tag in SelectedProject.Tags)
                            {
                                <span class="modal-chip">@tag</span>
                            }
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
}

<!-- Zoom Overlay -->
@if (ZoomedImageUrl != null)
{
    <div class="zoom-overlay" @onclick="CloseZoom">
        <button class="zoom-close" @onclick="CloseZoom" @onclick:stopPropagation="true">✕</button>
        <img src="@ZoomedImageUrl" alt="Zoomed" @onclick:stopPropagation="true" />
    </div>
}

@code {

    // ─── Media types ───────────────────────────────────────────
    private enum MediaItemType { Image, Video }

    private class MediaItem
    {
        public MediaItemType Type { get; set; }
        public string Url { get; set; } = "";
    }

    // Builds ordered media list: videos first, then images
    // Prefixes each filename with the project folder path
    private List<MediaItem> GetAllMedia(Project p)
    {
        var result = new List<MediaItem>();
        var folder = p.Folder ?? "";

        if (p.VideoUrls != null)
            foreach (var v in p.VideoUrls)
                result.Add(new MediaItem { Type = MediaItemType.Video, Url = folder + v });

        if (p.Images != null)
            foreach (var img in p.Images)
                result.Add(new MediaItem { Type = MediaItemType.Image, Url = folder + img });

        return result;
    }

    // ─── State ─────────────────────────────────────────────────
    private List<Project> AllProjects = new();
    private bool IsLoading = true;

    private List<string> Filters = new()
    {
        "All", "Motion Design", "Mixed Media", "Graphic Design", "Photography"
    };
    private string ActiveFilter = "All";

    private IEnumerable<Project> FilteredProjects =>
        ActiveFilter == "All"
            ? AllProjects
            : AllProjects.Where(p => p.Category == ActiveFilter);

    private int ComingSoonCount => Math.Max(0, 3 - FilteredProjects.Count());

    private void SetFilter(string filter)
    {
        ActiveFilter = filter;
        CloseModal();
    }

    // ─── Load from Supabase ────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        AllProjects = await Supabase.GetProjectsAsync();
        IsLoading = false;
    }

    // ─── Modal ─────────────────────────────────────────────────
    private Project? SelectedProject;
    private string? ZoomedImageUrl;
    private int _currentImageIndex = 0;
    private int CurrentImageIndex => _currentImageIndex;

    private void OpenModal(Project project)
    {
        SelectedProject = project;
        _currentImageIndex = 0;
        ZoomedImageUrl = null;
    }

    private void CloseModal()
    {
        SelectedProject = null;
        ZoomedImageUrl = null;
    }

    private async Task SelectMedia(int idx)
    {
        _currentImageIndex = idx;
        StateHasChanged();

        if (SelectedProject != null)
        {
            var media = GetAllMedia(SelectedProject);
            if (idx < media.Count && media[idx].Type == MediaItemType.Video)
            {
                await Task.Delay(50);
                await JS.InvokeVoidAsync("eval",
                    "var v = document.querySelector('.modal-main-video'); if(v){ v.pause(); v.load(); v.play().catch(()=>{}); }");
            }
        }
    }

    private async Task NextImage()
    {
        if (SelectedProject == null) return;
        var count = GetAllMedia(SelectedProject).Count;
        if (_currentImageIndex < count - 1)
            await SelectMedia(_currentImageIndex + 1);
    }

    private async Task PrevImage()
    {
        if (_currentImageIndex > 0)
            await SelectMedia(_currentImageIndex - 1);
    }

    private void OpenZoom(string url) => ZoomedImageUrl = url;
    private void CloseZoom() => ZoomedImageUrl = null;
}
