@page "/portfolio"

<PageTitle>Portfolio — Charmone Strauss</PageTitle>

<div class="portfolio-page">

    <!-- Page Header -->
    <section class="portfolio-header">
        <div class="portfolio-header-inner">
            <p class="portfolio-eyebrow">Creative Work</p>
            <h1 class="portfolio-title">Portfolio</h1>
            <p class="portfolio-subtitle">
                A collection of projects spanning photography, graphic design, and multimedia storytelling.
            </p>
        </div>
    </section>

    <!-- Filter Bar -->
    <section class="portfolio-filters">
        <div class="portfolio-filters-inner">
            @foreach (var filter in Filters)
            {
                <button class="filter-btn @(ActiveFilter == filter ? "active" : "")"
                        @onclick="() => SetFilter(filter)">
                    @filter
                </button>
            }
        </div>
    </section>

    <!-- Project Grid -->
    <section class="portfolio-grid-section">
        <div class="portfolio-grid">
            @foreach (var project in FilteredProjects)
            {
                <div class="project-card" @onclick="() => OpenModal(project)">
                    <div class="project-card-image">
                        @if (!string.IsNullOrEmpty(project.ThumbnailUrl))
                        {
                            <img src="@project.ThumbnailUrl" alt="@project.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="project-card-placeholder">
                                <span class="placeholder-icon">🖼</span>
                            </div>
                        }
                        <div class="project-card-overlay">
                            <span class="view-label">View Project</span>
                        </div>
                    </div>
                    <div class="project-card-info">
                        <span class="project-tag">@project.Category</span>
                        <h3 class="project-card-title">@project.Title</h3>
                        <p class="project-card-desc">@project.ShortDescription</p>
                        <div class="project-card-meta">
                            <span class="project-term">@project.Term</span>
                            <div class="project-media-icons">
                                @if (project.HasImages)
                                {
                                    <span title="Images">📷</span>
                                }
                                @if (project.HasVideo)
                                {
                                    <span title="Video">🎬</span>
                                }
                                @if (project.HasPdf)
                                {
                                    <span title="PDF">📄</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Coming Soon Placeholder Cards -->
            @for (int i = 0; i < ComingSoonCount; i++)
            {
                <div class="project-card coming-soon">
                    <div class="project-card-image">
                        <div class="project-card-placeholder">
                            <span class="placeholder-icon coming-soon-icon">✦</span>
                            <span class="coming-soon-text">Coming Soon</span>
                        </div>
                    </div>
                    <div class="project-card-info">
                        <span class="project-tag">—</span>
                        <h3 class="project-card-title">New Project</h3>
                        <p class="project-card-desc">More work coming soon.</p>
                    </div>
                </div>
            }
        </div>
    </section>

</div>

<!-- Modal Lightbox -->
@if (SelectedProject != null)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-panel" @onclick:stopPropagation="true">

            <button class="modal-close" @onclick="CloseModal" title="Close">✕</button>

            <div class="modal-body">

                <!-- Media Section -->
                <div class="modal-media">
                    @if (SelectedProject.Images != null && SelectedProject.Images.Count > 0)
                    {
                        <div class="modal-image-viewer">
                            <img src="@SelectedProject.Images[CurrentImageIndex]"
                                 alt="@SelectedProject.Title image @(CurrentImageIndex + 1)"
                                 class="modal-main-image"
                                 @onclick="() => OpenZoom(SelectedProject.Images[CurrentImageIndex])"
                                 @onclick:stopPropagation="true" />

                            @if (SelectedProject.Images.Count > 1)
                            {
                                <div class="modal-image-nav">
                                    <button class="img-nav-btn" @onclick="PrevImage"
                                            disabled="@(CurrentImageIndex == 0)">
                                        ‹
                                    </button>
                                    <span class="img-counter">
                                        @(CurrentImageIndex + 1) / @SelectedProject.Images.Count
                                    </span>
                                    <button class="img-nav-btn" @onclick="NextImage"
                                            disabled="@(CurrentImageIndex == SelectedProject.Images.Count - 1)">
                                        ›
                                    </button>
                                </div>

                                <div class="modal-thumbnails">
                                    @for (int i = 0; i < SelectedProject.Images.Count; i++)
                                    {
                                        int idx = i;
                                        <img src="@SelectedProject.Images[i]"
                                             alt="Thumbnail @(i + 1)"
                                             class="modal-thumb @(CurrentImageIndex == idx ? "active" : "")"
                                             @onclick="() => CurrentImageIndex = idx" />
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="modal-no-media">
                            <span>🖼</span>
                            <p>Images coming soon</p>
                        </div>
                    }
                </div>

                <!-- Info Section -->
                <div class="modal-info">
                    <span class="modal-tag">@SelectedProject.Category</span>
                    <h2 class="modal-title">@SelectedProject.Title</h2>
                    <p class="modal-term">@SelectedProject.Term</p>
                    <p class="modal-description">@SelectedProject.FullDescription</p>

                    <!-- PDF link -->
                    @if (SelectedProject.HasPdf && !string.IsNullOrEmpty(SelectedProject.PdfUrl))
                    {
                        <a href="@SelectedProject.PdfUrl" target="_blank" class="modal-pdf-btn">
                            📄 View PDF Document
                        </a>
                    }

                    <!-- Video embed -->
                    @if (SelectedProject.HasVideo && !string.IsNullOrEmpty(SelectedProject.VideoUrl))
                    {
                        <div class="modal-video-wrap">
                            <video controls class="modal-video">
                                <source src="@SelectedProject.VideoUrl" type="video/mp4" />
                                Your browser does not support video.
                            </video>
                        </div>
                    }

                    <!-- Tags -->
                    @if (SelectedProject.Tags != null && SelectedProject.Tags.Count > 0)
                    {
                        <div class="modal-tags">
                            @foreach (var tag in SelectedProject.Tags)
                            {
                                <span class="modal-chip">@tag</span>
                            }
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
}

<!-- Zoom Overlay -->
@if (ZoomedImageUrl != null)
{
    <div class="zoom-overlay" @onclick="CloseZoom">
        <button class="zoom-close" @onclick="CloseZoom" @onclick:stopPropagation="true">✕</button>
        <img src="@ZoomedImageUrl" alt="Zoomed image" @onclick:stopPropagation="true" />
    </div>
}

