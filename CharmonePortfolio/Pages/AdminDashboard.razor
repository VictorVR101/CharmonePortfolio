@page "/admin/dashboard"
@using CharmonePortfolio.Services
@using Microsoft.AspNetCore.Components.Forms
@inject SupabaseService Supabase
@inject NavigationManager Nav

@if (!Supabase.IsAuthenticated)
{
    Nav.NavigateTo("/admin");
    return;
}

<div class="admin-page">

    <!-- Header -->
    <div class="admin-header">
        <div>
            <p class="admin-eyebrow">Admin Dashboard</p>
            <h1 class="admin-title">Projects</h1>
        </div>
        <div style="display:flex;gap:1rem;align-items:center;">
            <button class="btn-primary" @onclick="ShowAddForm">+ Add Project</button>
            <button class="btn-outline" @onclick="Logout">Sign Out</button>
        </div>
    </div>

    <!-- Status message -->
    @if (!string.IsNullOrEmpty(StatusMessage))
    {
        <div class="admin-status @(StatusIsError ? "status-error" : "status-success")">
            @StatusMessage
        </div>
    }

    <!-- Add / Edit Form -->
    @if (ShowForm)
    {
        <div class="admin-form-wrap">
            <h2 class="admin-form-title">@(EditingProject?.Id == null ? "Add New Project" : "Edit Project")</h2>

            <div class="admin-form-grid">

                <!-- Title -->
                <div class="form-group admin-full">
                    <label class="form-label">Title *</label>
                    <input class="form-input" @bind="Form.Title" placeholder="e.g. Bauhaus Pop-Up Book" />
                </div>

                <!-- Subject -->
                <div class="form-group">
                    <label class="form-label">Subject</label>
                    <select class="form-input form-select" @bind="Form.Subject">
                        <option value="">Select subject</option>
                        <option value="Design Studio">Design Studio</option>
                        <option value="Visual Communication">Visual Communication</option>
                    </select>
                </div>

                <!-- Category -->
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <select class="form-input form-select" @bind="Form.Category">
                        <option value="">Select category</option>
                        <option value="Mixed Media">Mixed Media</option>
                        <option value="Graphic Design">Graphic Design</option>
                        <option value="Motion Design">Motion Design</option>
                        <option value="Photography">Photography</option>
                    </select>
                </div>

                <!-- Term -->
                <div class="form-group">
                    <label class="form-label">Term</label>
                    <select class="form-input form-select" @bind="Form.Term">
                        <option value="">Select term</option>
                        <option value="Term 1">Term 1</option>
                        <option value="Term 2">Term 2</option>
                        <option value="Term 3">Term 3</option>
                        <option value="Term 4">Term 4</option>
                    </select>
                </div>

                <!-- Folder -->
                <div class="form-group">
                    <label class="form-label">Folder name</label>
                    <input class="form-input" @bind="FolderName"
                           placeholder="e.g. ds-p1-t2" />
                    <p class="admin-hint">Short name only — e.g. <strong>ds-p1-t2</strong>. Files will be stored under <strong>portfolio/{folder}/</strong></p>
                </div>

                <!-- Images upload -->
                <div class="form-group admin-full">
                    <label class="form-label">Images</label>
                    <InputFile OnChange="OnImagesSelected" multiple accept="image/*"
                               style="display:none" id="imageFilePicker" />
                    <button type="button" class="btn-upload" onclick="document.getElementById('imageFilePicker').click()">
                        📁 Browse Images
                    </button>
                    @if (SelectedImages.Count > 0)
                    {
                        <div class="upload-file-list">
                            @foreach (var f in SelectedImages)
                            {
                                <div class="upload-file-item @(f == SelectedImages[0] ? "upload-file-thumb" : "")">
                                    <span class="upload-file-icon">🖼</span>
                                    <span class="upload-file-name">@f.Name</span>
                                    <span class="upload-file-size">@FormatSize(f.Size)</span>
                                    @if (f == SelectedImages[0])
                                    {
                                        <span class="upload-badge">thumbnail</span>
                                    }
                                </div>
                            }
                        </div>
                        <p class="admin-hint">@SelectedImages.Count image(s) selected. First image will be used as thumbnail.</p>
                    }
                </div>

                <!-- PDF upload -->
                <div class="form-group admin-full">
                    <label class="form-label">PDF (optional)</label>
                    <InputFile OnChange="OnPdfSelected" accept=".pdf"
                               style="display:none" id="pdfFilePicker" />
                    <button type="button" class="btn-upload" onclick="document.getElementById('pdfFilePicker').click()">
                        📄 Browse PDF
                    </button>
                    @if (SelectedPdf != null)
                    {
                        <div class="upload-file-list">
                            <div class="upload-file-item">
                                <span class="upload-file-icon">📄</span>
                                <span class="upload-file-name">@SelectedPdf.Name</span>
                                <span class="upload-file-size">@FormatSize(SelectedPdf.Size)</span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Videos -->
                <div class="form-group admin-full">
                    <label class="form-label">Video filenames (one per line, optional)</label>
                    <textarea class="form-input form-textarea"
                              style="min-height:80px"
                              @bind="VideosText"
                              placeholder="animation-1.mp4&#10;animation-2.mp4"></textarea>
                </div>

                <!-- Tags -->
                <div class="form-group admin-full">
                    <label class="form-label">Tags (comma separated)</label>
                    <input class="form-input" @bind="TagsText" placeholder="Illustration, Typography, Branding" />
                </div>

                <!-- Description -->
                <div class="form-group admin-full">
                    <label class="form-label">Description</label>
                    <textarea class="form-input form-textarea" @bind="Form.Description"
                              placeholder="Brief description of the project..."></textarea>
                </div>

                <!-- Sort order + Featured -->
                <div class="form-group">
                    <label class="form-label">Sort order (lower = first)</label>
                    <input class="form-input" type="number" @bind="Form.SortOrder" />
                </div>

                <div class="form-group" style="justify-content:flex-end;padding-bottom:0.5rem;">
                    <label class="admin-checkbox-label">
                        <input type="checkbox" @bind="Form.Featured" />
                        <span>Featured project (gold border)</span>
                    </label>
                </div>

            </div>

            <!-- Upload progress -->
            @if (IsUploading)
            {
                <div class="upload-progress">
                    <div class="upload-progress-bar" style="width:@(UploadProgress)%"></div>
                </div>
                <p class="admin-hint" style="text-align:center;margin-top:0.5rem;">@UploadStatus</p>
            }

            <!-- Form actions -->
            <div class="admin-form-actions">
                <button class="btn-primary" @onclick="SaveProjectAsync" disabled="@(IsSaving || IsUploading)">
                    @(IsSaving ? "Saving..." : IsUploading ? "Uploading..." : (EditingProject?.Id == null ? "Add Project" : "Save Changes"))
                </button>
                <button class="btn-outline" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    }

    <!-- Projects table -->
    @if (IsLoading)
    {
        <p class="admin-loading">Loading projects...</p>
    }
    else if (Projects.Count == 0)
    {
        <p class="admin-empty">No projects yet. Click "Add Project" to get started.</p>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Title</th>
                        <th>Subject</th>
                        <th>Category</th>
                        <th>Term</th>
                        <th>Featured</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Projects)
                    {
                        <tr>
                            <td>@p.SortOrder</td>
                            <td><strong>@p.Title</strong></td>
                            <td>@p.Subject</td>
                            <td>@p.Category</td>
                            <td>@p.Term</td>
                            <td>@(p.Featured ? "⭐" : "—")</td>
                            <td>
                                <div style="display:flex;gap:0.5rem;">
                                    <button class="admin-btn-edit" @onclick="() => EditProject(p)">Edit</button>
                                    <button class="admin-btn-delete" @onclick="() => DeleteProjectAsync(p)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    private List<Project> Projects = new();
    private bool IsLoading = true;
    private bool IsSaving = false;
    private bool IsUploading = false;
    private bool ShowForm = false;
    private string StatusMessage = "";
    private bool StatusIsError = false;
    private int UploadProgress = 0;
    private string UploadStatus = "";

    // Form state
    private Project Form = new();
    private Project? EditingProject;
    private string FolderName = "";
    private string VideosText = "";
    private string TagsText = "";

    // File picker state
    private List<IBrowserFile> SelectedImages = new();
    private IBrowserFile? SelectedPdf = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectsAsync();
    }

    private async Task LoadProjectsAsync()
    {
        IsLoading = true;
        Projects = await Supabase.GetProjectsAsync();
        IsLoading = false;
    }

    private void ShowAddForm()
    {
        Form = new Project();
        EditingProject = new Project();
        FolderName = "";
        VideosText = "";
        TagsText = "";
        SelectedImages = new();
        SelectedPdf = null;
        ShowForm = true;
        StatusMessage = "";
    }

    private void EditProject(Project p)
    {
        EditingProject = p;
        Form = new Project
        {
            Id = p.Id,
            Title = p.Title,
            Description = p.Description,
            Subject = p.Subject,
            Category = p.Category,
            Term = p.Term,
            Folder = p.Folder,
            Thumbnail = p.Thumbnail,
            Images = new List<string>(p.Images),
            VideoUrls = new List<string>(p.VideoUrls),
            PdfUrl = p.PdfUrl,
            Tags = new List<string>(p.Tags),
            Featured = p.Featured,
            SortOrder = p.SortOrder
        };
        // Strip the folder prefix for display in the text box
        FolderName = p.Folder.Replace("portfolio/", "").Trim('/');
        VideosText = string.Join("\n", p.VideoUrls);
        TagsText = string.Join(", ", p.Tags);
        SelectedImages = new();
        SelectedPdf = null;
        ShowForm = true;
        StatusMessage = "";
    }

    private void CancelForm()
    {
        ShowForm = false;
        EditingProject = null;
    }

    private void OnImagesSelected(InputFileChangeEventArgs e)
    {
        SelectedImages = e.GetMultipleFiles(50).ToList();
    }

    private void OnPdfSelected(InputFileChangeEventArgs e)
    {
        SelectedPdf = e.File;
    }

    private async Task SaveProjectAsync()
    {
        if (string.IsNullOrWhiteSpace(Form.Title))
        {
            SetStatus("Title is required.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(FolderName))
        {
            SetStatus("Folder name is required.", true);
            return;
        }

        IsSaving = true;

        // Build folder path
        var folder = FolderName.Trim('/').ToLower();
        Form.Folder = $"portfolio/{folder}";

        // Upload images if any selected
        if (SelectedImages.Count > 0)
        {
            IsUploading = true;
            var uploadedNames = new List<string>();

            for (int i = 0; i < SelectedImages.Count; i++)
            {
                var file = SelectedImages[i];
                UploadStatus = $"Uploading {file.Name} ({i + 1}/{SelectedImages.Count})...";
                UploadProgress = (int)((i / (double)SelectedImages.Count) * 100);
                StateHasChanged();

                var bytes = await ReadFileAsync(file);
                var contentType = file.ContentType ?? "image/jpeg";
                var result = await Supabase.UploadFileAsync(folder, file.Name, bytes, contentType);

                if (result.Success)
                {
                    uploadedNames.Add(file.Name);
                }
                else
                {
                    SetStatus($"Failed to upload {file.Name}: {result.Error}", true);
                    IsSaving = false;
                    IsUploading = false;
                    return;
                }
            }

            Form.Images = uploadedNames;
            Form.Thumbnail = uploadedNames[0]; // first image = thumbnail
            UploadProgress = 100;
            IsUploading = false;
        }

        // Upload PDF if selected
        if (SelectedPdf != null)
        {
            IsUploading = true;
            UploadStatus = $"Uploading {SelectedPdf.Name}...";
            StateHasChanged();

            var bytes = await ReadFileAsync(SelectedPdf);
            var result = await Supabase.UploadFileAsync(folder, SelectedPdf.Name, bytes, "application/pdf");

            if (result.Success)
            {
                Form.PdfUrl = SelectedPdf.Name;
            }
            else
            {
                SetStatus($"Failed to upload PDF: {result.Error}", true);
                IsSaving = false;
                IsUploading = false;
                return;
            }

            IsUploading = false;
        }

        // Parse videos and tags
        Form.VideoUrls = VideosText
            .Split('\n', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim())
            .Where(s => !string.IsNullOrEmpty(s))
            .ToList();

        Form.Tags = TagsText
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim())
            .Where(s => !string.IsNullOrEmpty(s))
            .ToList();

        bool success;
        if (string.IsNullOrEmpty(Form.Id))
            success = await Supabase.CreateProjectAsync(Form);
        else
            success = await Supabase.UpdateProjectAsync(Form);

        if (success)
        {
            SetStatus(string.IsNullOrEmpty(Form.Id) ? "Project added!" : "Project updated!", false);
            ShowForm = false;
            await LoadProjectsAsync();
        }
        else
        {
            SetStatus("Something went wrong saving the project.", true);
        }

        IsSaving = false;
    }

    private async Task DeleteProjectAsync(Project p)
    {
        if (string.IsNullOrEmpty(p.Id)) return;

        var success = await Supabase.DeleteProjectAsync(p.Id);
        if (success)
        {
            SetStatus($"'{p.Title}' deleted.", false);
            await LoadProjectsAsync();
        }
        else
        {
            SetStatus("Could not delete project.", true);
        }
    }

    private static async Task<byte[]> ReadFileAsync(IBrowserFile file)
    {
        // Max 50MB per Supabase free tier limit
        using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return ms.ToArray();
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024} KB";
        return $"{bytes / (1024 * 1024.0):F1} MB";
    }

    private void SetStatus(string msg, bool isError)
    {
        StatusMessage = msg;
        StatusIsError = isError;
    }

    private void Logout()
    {
        Supabase.Logout();
        Nav.NavigateTo("/");
    }
}

<style>
    .admin-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 2rem 6rem;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .admin-eyebrow {
        font-size: 0.7rem;
        letter-spacing: 4px;
        color: var(--color-gold);
        text-transform: uppercase;
        margin-bottom: 0.5rem;
    }

    .admin-title {
        font-size: 3.5rem;
        font-weight: 400;
        color: var(--color-accent);
        line-height: 1;
        letter-spacing: -1px;
    }

    .admin-status {
        padding: 0.75rem 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        border-left: 3px solid currentColor;
    }

    /* ── Form ── */
    .admin-form-wrap {
        background-color: var(--color-card);
        border: 1px solid var(--color-border);
        padding: 2rem;
        margin-bottom: 2.5rem;
    }

    .admin-form-title {
        font-size: 1.4rem;
        font-weight: 400;
        color: var(--color-accent);
        margin-bottom: 1.5rem;
    }

    .admin-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.2rem;
    }

    .admin-full {
        grid-column: 1 / -1;
    }

    .form-select {
        cursor: pointer;
    }

    .admin-hint {
        font-size: 0.75rem;
        color: var(--color-text-secondary);
        margin-top: 0.4rem;
        letter-spacing: 0.5px;
    }

    .admin-checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.85rem;
        color: var(--color-text-secondary);
        cursor: pointer;
        padding-top: 1.8rem;
    }

        .admin-checkbox-label input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: var(--color-accent);
            cursor: pointer;
        }

    .admin-form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--color-border);
    }

    /* ── Upload button & file list ── */
    .btn-upload {
        background: transparent;
        border: 1px solid var(--color-gold);
        color: var(--color-gold);
        padding: 0.5rem 1.2rem;
        font-size: 0.8rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        font-family: Georgia, serif;
        transition: all 0.2s;
        margin-bottom: 0.75rem;
    }

        .btn-upload:hover {
            background-color: var(--color-gold);
            color: #fff;
        }

    .upload-file-list {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-top: 0.5rem;
    }

    .upload-file-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.82rem;
        color: var(--color-text-secondary);
        padding: 0.4rem 0.6rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
    }

    .upload-file-thumb {
        border-color: var(--color-gold);
    }

    .upload-file-name {
        flex: 1;
        color: var(--color-text-primary);
        font-size: 0.85rem;
    }

    .upload-file-size {
        color: var(--color-text-secondary);
        font-size: 0.75rem;
    }

    .upload-badge {
        font-size: 0.65rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--color-gold);
        border: 1px solid var(--color-gold);
        padding: 0.1rem 0.4rem;
    }

    /* ── Upload progress bar ── */
    .upload-progress {
        height: 3px;
        background: var(--color-border);
        margin-top: 1rem;
        overflow: hidden;
    }

    .upload-progress-bar {
        height: 100%;
        background: var(--color-gold);
        transition: width 0.3s ease;
    }

    /* ── Table ── */
    .admin-table-wrap {
        overflow-x: auto;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
    }

        .admin-table th {
            text-align: left;
            font-size: 0.65rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--color-gold);
            padding: 0.8rem 1rem;
            border-bottom: 1px solid var(--color-border);
        }

        .admin-table td {
            padding: 0.9rem 1rem;
            border-bottom: 1px solid var(--color-border);
            color: var(--color-text-secondary);
            vertical-align: middle;
        }

        .admin-table tr:last-child td {
            border-bottom: none;
        }

        .admin-table tr:hover td {
            background-color: var(--color-surface);
        }

        .admin-table strong {
            color: var(--color-text-primary);
        }

    .admin-btn-edit {
        background: transparent;
        border: 1px solid var(--color-gold);
        color: var(--color-gold);
        padding: 0.3rem 0.8rem;
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
        font-family: Georgia, serif;
    }

        .admin-btn-edit:hover {
            background-color: var(--color-gold);
            color: #fff;
        }

    .admin-btn-delete {
        background: transparent;
        border: 1px solid var(--color-accent);
        color: var(--color-accent);
        padding: 0.3rem 0.8rem;
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
        font-family: Georgia, serif;
    }

        .admin-btn-delete:hover {
            background-color: var(--color-accent);
            color: var(--color-navbar-text);
        }

    .admin-loading,
    .admin-empty {
        text-align: center;
        padding: 4rem;
        color: var(--color-text-secondary);
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    @@media (max-width: 768px) {
        .admin-form-grid {
            grid-template-columns: 1fr;
        }

        .admin-full {
            grid-column: 1;
        }

        .admin-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>